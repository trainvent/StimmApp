rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'service@trainvent.com';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasStateValue(data) {
      return data.keys().hasAny(['state']) &&
             data.state is string &&
             data.state.size() > 0;
    }

    function hasCountryCode(data) {
      return data.keys().hasAny(['countryCode']) &&
             data.countryCode is string &&
             data.countryCode.size() > 0;
    }

    function supportsStateScope(data) {
      return (hasCountryCode(data) && data.countryCode == 'DE') ||
             (!hasCountryCode(data) && hasStateValue(data));
    }

    function hasValidUserStateCountry(data) {
      // DE users (and legacy users with existing state but no countryCode)
      // may keep a non-empty state. Others must keep state empty/null/absent.
      return supportsStateScope(data)
        ? hasStateValue(data)
        : (!data.keys().hasAny(['state']) || data.state == null || data.state == '');
    }

    function requesterSupportsStateScope() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             supportsStateScope(
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data
             );
    }

    function hasValidContentState(data) {
      // Outside DE scope, content cannot be state-scoped.
      return requesterSupportsStateScope()
        ? true
        : (!data.keys().hasAny(['state']) || data.state == null || data.state == '');
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      // Main Profile: Public Read, Owner Write
      allow read: if true;
      allow write: if isAdmin() ||
                    (isOwner(userId) && hasValidUserStateCountry(request.resource.data));

      match /blockedUsers/{blockedUserId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Explicitly handle subcollections for history
      match /signedPetitions/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /votedPolls/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Catch-all for other subcollections (if any)
      match /{subcollection}/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Petitions & Polls
    match /petitions/{document=**} {
      allow read: if true;
      allow write: if isAdmin() ||
                    (isAuthenticated() && hasValidContentState(request.resource.data));
    }

    match /polls/{document=**} {
      allow read: if true;
      allow write: if isAdmin() ||
                    (isAuthenticated() && hasValidContentState(request.resource.data));
    }

    match /moderationReports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Verification Codes: Blocked
    match /verificationCodes/{document=**} {
      allow read, write: if false;
    }

    // Default Fallback
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
