rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'service@trainvent.com';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasStateValue(data) {
      return data.keys().hasAny(['state']) &&
             data.state is string &&
             data.state.size() > 0;
    }

    function hasCountryCode(data) {
      return data.keys().hasAny(['countryCode']) &&
             data.countryCode is string &&
             data.countryCode.size() > 0;
    }

    function supportsStateScope(data) {
      return (hasCountryCode(data) && data.countryCode == 'DE') ||
             (!hasCountryCode(data) && hasStateValue(data));
    }

    function hasValidUserStateCountry(data) {
      // DE users (and legacy users with existing state but no countryCode)
      // may keep a non-empty state. Others must keep state empty/null/absent.
      return supportsStateScope(data)
        ? hasStateValue(data)
        : (!data.keys().hasAny(['state']) || data.state == null || data.state == '');
    }

    function requesterSupportsStateScope() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             supportsStateScope(
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data
             );
    }

    function hasValidContentState(data) {
      // Outside DE scope, content cannot be state-scoped.
      return requesterSupportsStateScope()
        ? true
        : (!data.keys().hasAny(['state']) || data.state == null || data.state == '');
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/pollGroups/$(groupId));
    }

    function groupDocAfter(groupId) {
      return getAfter(/databases/$(database)/documents/pollGroups/$(groupId));
    }

    function groupExists(groupId) {
      return exists(/databases/$(database)/documents/pollGroups/$(groupId));
    }

    function isPollGroupCreator(groupId) {
      return isAuthenticated() &&
             groupExists(groupId) &&
             groupDoc(groupId).data.createdBy == request.auth.uid;
    }

    function isPollGroupAdmin(groupId) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/pollGroups/$(groupId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/pollGroups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    function isPollGroupCreatorAfter(groupId) {
      return isAuthenticated() &&
             groupDocAfter(groupId).data.createdBy == request.auth.uid;
    }

    function isPollGroupMember(groupId) {
      return isAuthenticated() &&
             groupExists(groupId) &&
             request.auth.uid in groupDoc(groupId).data.memberIds;
    }

    function isPollGroupMemberAfter(groupId) {
      return isAuthenticated() &&
             request.auth.uid in groupDocAfter(groupId).data.memberIds;
    }

    function isValidPollGroupCreate() {
      return request.resource.data.createdBy == request.auth.uid &&
             request.resource.data.name is string &&
             request.resource.data.memberIds is list &&
             request.resource.data.memberIds.size() == 1 &&
             request.auth.uid in request.resource.data.memberIds &&
             request.resource.data.accessMode is string &&
             request.resource.data.inviteLinkEnabled is bool;
    }

    function canReadPollGroup(groupId) {
      return isAdmin() ||
             isPollGroupMember(groupId) ||
             (isAuthenticated() &&
              groupExists(groupId) &&
              groupDoc(groupId).data.accessMode != 'private');
    }

    function canSelfJoinPollGroup(groupId) {
      return isAuthenticated() &&
             groupExists(groupId) &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberIds']) &&
             request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
             request.auth.uid in request.resource.data.memberIds &&
             !(request.auth.uid in resource.data.memberIds);
    }

    function canSelfLeavePollGroup(groupId) {
      return isAuthenticated() &&
             groupExists(groupId) &&
             resource.data.createdBy != request.auth.uid &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberIds']) &&
             resource.data.memberIds.size() == request.resource.data.memberIds.size() + 1 &&
             request.auth.uid in resource.data.memberIds &&
             !(request.auth.uid in request.resource.data.memberIds);
    }

    // --- Collection Rules ---

    // Users Collection
    match /users/{userId} {
      // Main Profile: Public Read, Owner Write
      allow read: if true;
      allow write: if isAdmin() ||
                    (isOwner(userId) && hasValidUserStateCountry(request.resource.data));

      match /blockedUsers/{blockedUserId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /groupAccessNotifications/{notificationId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        allow create: if isAdmin() ||
                      isOwner(userId) ||
                      (isAuthenticated() &&
                       request.resource.data.groupId is string &&
                       request.resource.data.recipientUid == userId &&
                       (
                         (
                           groupDocAfter(request.resource.data.groupId).data.createdBy == request.auth.uid ||
                           request.resource.data.actorUid == request.auth.uid
                         )
                       ));
      }

      // Explicitly handle subcollections for history
      match /signedPetitions/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /votedPolls/{docId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Catch-all for other subcollections (if any)
      match /{subcollection}/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Petitions & Polls
    match /petitions/{document=**} {
      allow read: if true;
      allow write: if isAdmin() ||
                    (isAuthenticated() && hasValidContentState(request.resource.data));
    }

    match /polls/{document=**} {
      allow read: if true;
      allow write: if isAdmin() ||
                    (isAuthenticated() && hasValidContentState(request.resource.data));
    }

    match /pollGroups/{groupId} {
      allow read: if isAdmin() ||
                   (isAuthenticated() &&
                    (
                      request.auth.uid in resource.data.memberIds ||
                      resource.data.accessMode != 'private'
                    ));
      allow create: if isAdmin() ||
                    (isAuthenticated() && isValidPollGroupCreate());
      allow update: if isAdmin() ||
                    (isAuthenticated() &&
                     resource.data.createdBy == request.auth.uid) ||
                    isPollGroupAdmin(groupId) ||
                    canSelfJoinPollGroup(groupId) ||
                    canSelfLeavePollGroup(groupId);
      allow delete: if isAdmin() ||
                    (isAuthenticated() &&
                     resource.data.createdBy == request.auth.uid) ||
                    isPollGroupAdmin(groupId);

      match /members/{memberId} {
        allow read: if canReadPollGroup(groupId);
        allow create: if isAdmin() ||
                      (isPollGroupCreatorAfter(groupId) &&
                       request.resource.data.joinedBy == request.auth.uid) ||
                      (isPollGroupMemberAfter(groupId) &&
                       memberId == request.auth.uid &&
                       request.resource.data.joinedBy == request.auth.uid);
        allow update, delete: if isAdmin() ||
                              isPollGroupCreator(groupId) ||
                              isPollGroupAdmin(groupId) ||
                              (isAuthenticated() &&
                               memberId == request.auth.uid &&
                               isPollGroupMember(groupId));
      }

      match /allowedMembers/{allowedMemberId} {
        allow read: if isAdmin() || isPollGroupCreator(groupId) || isPollGroupAdmin(groupId);
        allow create: if isAdmin() || isPollGroupCreatorAfter(groupId) || isPollGroupAdmin(groupId);
        allow update, delete: if isAdmin() || isPollGroupCreator(groupId) || isPollGroupAdmin(groupId);
      }

      match /allowedDomains/{allowedDomainId} {
        allow read: if isAdmin() || isPollGroupCreator(groupId) || isPollGroupAdmin(groupId);
        allow create: if isAdmin() || isPollGroupCreatorAfter(groupId) || isPollGroupAdmin(groupId);
        allow update, delete: if isAdmin() || isPollGroupCreator(groupId) || isPollGroupAdmin(groupId);
      }
    }

    match /moderationReports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Verification Codes: Blocked
    match /verificationCodes/{document=**} {
      allow read, write: if false;
    }

    // Default Fallback
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
