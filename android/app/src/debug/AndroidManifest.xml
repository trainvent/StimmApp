<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <application>
        <!-- Debug-only alias so local dev builds can claim the dev web host. -->
        <activity-alias
            android:name="de.lemarq.stimmapp.DebugDeepLinkActivity"
            android:exported="true"
            android:targetActivity="de.lemarq.stimmapp.MainActivity">
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="https"
                    android:host="${debugDeepLinkHost}"
                    android:pathPrefix="/petition" />
            </intent-filter>
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:scheme="https"
                    android:host="${debugDeepLinkHost}"
                    android:pathPrefix="/poll" />
            </intent-filter>
        </activity-alias>
    </application>
</manifest>
