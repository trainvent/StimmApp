graph TD
    %% Actors
    User(("User"))
    Admin(("Admin"))

    %% Mobile Client
    subgraph MobileClient ["Mobile Client (Flutter)"]
        direction TB
        subgraph AuthModule ["Auth Module"]
            SignIn["Sign In / Register"]
            EmailVer["Email Verification"]
        end

        subgraph ContentModule ["Content Module"]
            Feed["Feed (Polls/Petitions)"]
            CreatorStudio["Creator Studio"]
            DetailView["Detail View (Vote/Sign)"]
        end

        subgraph UserModule ["User Module"]
            Profile["Profile & Settings"]
            ProUI["Pro Membership UI"]
        end

        subgraph AdminModule ["Admin Module"]
            AdminDash["Admin Dashboard"]
        end
    end

    %% Web Portal
    subgraph WebPortal ["Web Portal"]
        WebDelete["Delete Account Page"]
    end

    %% External Services
    subgraph ExternalServices ["External Services"]
        RC["RevenueCat"]
        Places["Google Places"]
        EmailService["SMTP / Email"]
    end

    %% Firebase Backend
    subgraph FirebaseBackend ["Firebase Backend"]
        Auth["Firebase Auth"]
        DB[("Firestore DB")]
        Storage[("File Storage")]
        Hosting["Hosting"]
        
        subgraph CloudFunctions ["Cloud Functions (v2)"]
            FuncAuth[["Auth Logic<br>(OTP, Verification)"]]
            FuncSub[["Scheduled Tasks<br>(Subscription Check)"]]
            FuncCleanup[["Triggers<br>(User Cleanup)"]]
            FuncAdmin[["Callables<br>(Admin Actions)"]]
        end
    end

    %% Relationships
    %% User Actions
    User -.-> SignIn
    User -.-> Feed
    User -.-> CreatorStudio
    User -.-> DetailView
    User -.-> ProUI
    User -.-> WebDelete

    %% Admin Actions
    Admin -.-> AdminDash

    %% Mobile App Integration
    SignIn --> Auth
    EmailVer --> FuncAuth
    Feed <--> DB
    CreatorStudio --> DB
    CreatorStudio --> Storage
    CreatorStudio --> Places
    DetailView --> DB
    ProUI <--> RC
    AdminDash --> FuncAdmin

    %% Web Integration
    Hosting --> WebDelete
    WebDelete --> Auth
    WebDelete --> FuncCleanup

    %% Backend Logic
    FuncAuth --> EmailService
    FuncSub --> DB
    FuncCleanup --> DB
    FuncCleanup --> Storage
    FuncAdmin --> Auth
    FuncAdmin --> DB